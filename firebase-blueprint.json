{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Represents a registered player",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gender": { "type": "string", "enum": ["Masculino", "Feminino"] },
        "hierarchyValue": { "type": "integer" }
      },
      "required": ["id", "name", "gender", "hierarchyValue"]
    },
    "AppState": {
      "title": "AppState",
      "description": "Represents the active match roster and app settings",
      "type": "object",
      "properties": {
        "teamA": {
          "type": "array",
          "items": { "type": "string" }
        },
        "teamB": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reserves": {
          "type": "array",
          "items": { "type": "string" }
        },
        "theme": { "type": "string", "enum": ["claro", "escuro", "pastel"] },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "teamA": { "type": "array", "items": { "type": "string" } },
              "teamB": { "type": "array", "items": { "type": "string" } },
              "reserves": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "required": ["teamA", "teamB", "reserves", "theme", "history"]
    }
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "Player",
      "description": "The registered players collection"
    },
    "/appState/{stateId}": {
      "schema": "AppState",
      "description": "The application state singleton"
    }
  }
}
