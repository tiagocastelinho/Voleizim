{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Represents a registered player",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "gender": { "type": "string", "enum": ["Masculino", "Feminino"] },
        "hierarchyValue": { "type": "integer" }
      },
      "required": ["id", "name", "gender", "hierarchyValue"]
    },
    "AppState": {
      "title": "AppState",
      "description": "Represents the active match roster and app settings",
      "type": "object",
      "properties": {
        "teamA": {
          "type": "array",
          "items": { "$ref": "#/entities/Player" }
        },
        "teamB": {
          "type": "array",
          "items": { "$ref": "#/entities/Player" }
        },
        "reserves": {
          "type": "array",
          "items": { "$ref": "#/entities/Player" }
        },
        "registeredPlayers": {
          "type": "array",
          "items": { "$ref": "#/entities/Player" }
        },
        "theme": { "type": "string", "enum": ["claro", "escuro", "pastel"] },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "teamA": { "type": "array", "items": { "$ref": "#/entities/Player" } },
              "teamB": { "type": "array", "items": { "$ref": "#/entities/Player" } },
              "reserves": { "type": "array", "items": { "$ref": "#/entities/Player" } }
            }
          }
        },
        "alternatingOrder": { "type": "boolean" },
        "swapOrderMode": { "type": "string", "enum": ["A", "B"] },
        "consecutiveWinsTeam": { "type": "string", "enum": ["A", "B"] },
        "consecutiveWinsCount": { "type": "integer" },
        "lastWarnedRostersHash": { "type": "string" }
      },
      "required": ["teamA", "teamB", "reserves", "registeredPlayers", "theme", "history"]
    }
  },
  "firestore": {
    "/appState/{stateId}": {
      "schema": "AppState",
      "description": "The application state singleton"
    }
  }
}
